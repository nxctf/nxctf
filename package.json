{
  "name": "nxctf",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "predev": "node src/lib/scripts/gen-version.js",
    "prebuild": "node src/lib/scripts/gen-version.js",
    "prestart": "node src/lib/scripts/gen-version.js",
    "setup": "node db/build-init-sql.js",
    "update": "node db/update_schema.js",
    "update-types": "npx supabase gen types typescript --project-id \"$PROJECT_REF\" --schema public > src/lib/supabase/database.types.ts",
    "update-types:local": "npx supabase gen types typescript --local --schema public > src/lib/supabase/database.types.ts",
    "setting": "npm run dev",
    "clean": "rimraf .next",
    "dev": "rimraf .next-dev && next dev",
    "build": "rimraf .next && next build",
    "start": "next start",
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@marsidev/react-turnstile": "^1.5.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-form": "^1.21.2",
    "@tanstack/react-query": "^5.90.6",
    "@tanstack/react-query-devtools": "^5.90.6",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "jotai": "^2.15.1",
    "ky": "^1.11.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-joyride": "^3.1.0",
    "react-markdown": "^10.1.0",
    "recharts": "3.8.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.6",
